{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "cms://schemas/block.schema.json",
    "title": "CMS Block Manifest",
    "type": "object",
    "required": ["label", "group", "icon"],
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string"
        },
        "label": {
            "type": "string",
            "minLength": 1
        },
        "description": {
            "type": "string"
        },
        "group": {
            "type": "string",
            "minLength": 1
        },
        "icon": {
            "type": "string",
            "minLength": 1
        },
        "source": {
            "type": "string",
            "minLength": 1
        },
        "inlineEditable": {
            "type": "boolean"
        },
        "acceptsChildren": {
            "type": "boolean"
        },
        "allowedChildren": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "fields": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["key", "label", "type"],
                "additionalProperties": false,
                "properties": {
                    "key": {
                        "type": "string",
                        "minLength": 1
                    },
                    "label": {
                        "type": "string",
                        "minLength": 1
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "text",
                            "textarea",
                            "url",
                            "select",
                            "toggle",
                            "number",
                            "media",
                            "page-link"
                        ]
                    },
                    "placeholder": {
                        "type": "string"
                    },
                    "options": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["value", "label"],
                            "additionalProperties": false,
                            "properties": {
                                "value": {
                                    "type": "string"
                                },
                                "label": {
                                    "type": "string",
                                    "minLength": 1
                                }
                            }
                        }
                    }
                }
            }
        },
        "defaultData": {
            "type": "object"
        }
    }
}
