{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "cms://schemas/plugin.schema.json",
    "title": "CMS Plugin Manifest",
    "type": "object",
    "required": ["name", "entrypoint"],
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string"
        },
        "name": {
            "type": "string",
            "minLength": 1
        },
        "slug": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+$"
        },
        "version": {
            "type": "string",
            "minLength": 1
        },
        "description": {
            "type": "string"
        },
        "author": {
            "type": "string"
        },
        "entrypoint": {
            "type": "string",
            "minLength": 1
        },
        "provider": {
            "type": "string",
            "minLength": 1
        },
        "scopes": {
            "type": "array",
            "items": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*:(read|write)$"
            }
        },
        "migrations": {
            "type": ["string", "array"],
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "migration_paths": {
            "type": ["string", "array"],
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "model_namespace": {
            "type": "string",
            "minLength": 1
        },
        "models": {
            "type": "string",
            "minLength": 1
        },
        "admin_nav": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["group", "title", "href"],
                "additionalProperties": false,
                "properties": {
                    "group": {
                        "type": "string",
                        "minLength": 1
                    },
                    "title": {
                        "type": "string",
                        "minLength": 1
                    },
                    "href": {
                        "type": "string",
                        "minLength": 1
                    },
                    "icon": {
                        "type": "string",
                        "minLength": 1
                    },
                    "permission": {
                        "type": "string",
                        "minLength": 1
                    }
                }
            }
        }
    }
}
