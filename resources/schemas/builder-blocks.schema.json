{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "cms://schemas/builder-blocks.schema.json",
    "title": "CMS Builder Block Payload",
    "type": "array",
    "items": {
        "type": "object",
        "required": ["id", "type", "data"],
        "additionalProperties": false,
        "properties": {
            "id": {
                "type": "string",
                "minLength": 1
            },
            "type": {
                "type": "string",
                "minLength": 1
            },
            "data": {
                "type": ["object", "array"]
            },
            "order": {
                "type": "integer"
            }
        }
    }
}
