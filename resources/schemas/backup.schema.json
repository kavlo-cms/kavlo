{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "cms://schemas/backup.schema.json",
    "title": "CMS Backup Manifest",
    "type": "object",
    "required": [
        "filename",
        "created_at",
        "app_name",
        "app_url",
        "laravel",
        "php",
        "stats"
    ],
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string"
        },
        "filename": {
            "type": "string",
            "minLength": 1
        },
        "created_at": {
            "type": "string",
            "minLength": 1
        },
        "app_name": {
            "type": "string",
            "minLength": 1
        },
        "app_url": {
            "type": "string",
            "minLength": 1
        },
        "laravel": {
            "type": "string",
            "minLength": 1
        },
        "php": {
            "type": "string",
            "minLength": 1
        },
        "purpose": {
            "type": "string",
            "minLength": 1
        },
        "label": {
            "type": "string",
            "minLength": 1
        },
        "stats": {
            "type": "object",
            "required": [
                "database_tables",
                "public_files",
                "plugins",
                "themes"
            ],
            "additionalProperties": false,
            "properties": {
                "database_tables": {
                    "type": "integer"
                },
                "public_files": {
                    "type": "integer"
                },
                "plugins": {
                    "type": "integer"
                },
                "themes": {
                    "type": "integer"
                }
            }
        }
    }
}
